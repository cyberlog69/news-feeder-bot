# ════════════════════════════════════════════════════════
#  News Feeder Bot v3.0 — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control!
# ════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════
#  AI SUMMARIZATION — Choose ONE provider
#  Options: groq | ollama | huggingface | openrouter | gemini | extractive
# ════════════════════════════════════════════════════════

SUMMARIZER_PROVIDER=groq       # ← change this to switch providers


# ── Groq (RECOMMENDED — free 14,400 req/day, no credit card) ─────────────────
# Sign up free at: https://console.groq.com
# Free models: llama-3.1-8b-instant, llama-3.3-70b-versatile, mixtral-8x7b-32768
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant


# ── Ollama (LOCAL — unlimited, 100% free, full privacy) ──────────────────────
# Install from: https://ollama.com
# Pull model:   ollama pull llama3.2
# Then just set: SUMMARIZER_PROVIDER=ollama  (no API key needed!)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2


# ── Hugging Face (free tier — best for summarization model quality) ───────────
# Sign up free at: https://huggingface.co → Settings → Access Tokens → New token (read)
# Recommended model: facebook/bart-large-cnn (purpose-built for summarization)
HF_API_KEY=
HF_MODEL=facebook/bart-large-cnn


# ── OpenRouter (free tier — 100+ models via one API) ─────────────────────────
# Sign up free at: https://openrouter.ai
# Free models include: meta-llama/llama-3.1-8b-instruct:free, mistralai/mistral-7b:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free


# ── Gemini (Google — original provider, free tier) ───────────────────────────
# Get key free at: https://aistudio.google.com
GEMINI_API_KEY=


# ── Extractive (NO AI — zero cost, always works) ─────────────────────────────
# Set SUMMARIZER_PROVIDER=extractive to use keyword extraction (no API at all)
# Great as a fallback or if you don't want any AI dependency


# ════════════════════════════════════════════════════════
#  PLATFORM CONFIGURATION
#  Set at least ONE platform. Multiple platforms work simultaneously.
# ════════════════════════════════════════════════════════

# ── WhatsApp (Optional) ───────────────────────────────────
# Supports comma-separated multiple targets:
#   Phone number:  919876543210
#   Group ID:      120363409960337815@g.us
#   Group name:    My Cyber News Group
#   Multi-target:  120363@g.us,919876543210
#
# Run 'npm run list-groups' to find your group IDs.
WHATSAPP_TARGET=


# ── Telegram (Optional) ───────────────────────────────────
# Step 1: Message @BotFather on Telegram → /newbot → copy token
# Step 2: Run 'npm run list-telegram-chats' to find your chat ID
#
# Supports comma-separated multiple targets:
#   Personal chat:   123456789
#   Group:          -987654321
#   Channel:        @mychannel  OR  -1001234567890
#   Multi-target:   @mychannel,-1001234567890
TELEGRAM_BOT_TOKEN=
TELEGRAM_TARGET=


DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=📰 News Feeder Bot
# Optional: URL to a custom avatar image for the Discord bot
DISCORD_AVATAR_URL=


# ── Google Chat Space / Hangouts (Optional) ───────────────
# Step 1: Open Google Chat Space → Space Title → Apps & Integrations → Webhooks → Add Webhook
# Step 2: Copy the generated Webhook URL and paste below
GOOGLE_CHAT_WEBHOOK_URL=


# ── Slack (Optional) ──────────────────────────────────────
# Step 1: Slack App → Incoming Webhooks → Activate → Add New Webhook to Workspace
# Step 2: Copy Webhook URL and paste below
SLACK_WEBHOOK_URL=


# ── Microsoft Teams (Optional) ────────────────────────────
# Step 1: Teams Channel → Connectors / Workflows → Incoming Webhook → Copy URL
TEAMS_WEBHOOK_URL=


# ════════════════════════════════════════════════════════
#  DEPLOYMENT / INFRASTRUCTURE
# ════════════════════════════════════════════════════════

# NODE_ENV — set to 'production' on cloud deployments
# NODE_ENV=production

# PORT — auto-set by cloud platforms (Railway, Render, Fly.io)
# PORT=3000

# DASHBOARD_TOKEN — protect the /trigger endpoint (recommended on cloud deployments)
# Leave empty to allow unauthenticated access (fine on localhost)
# Generate one: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# DASHBOARD_TOKEN=your_secret_token_here

# CHROME_PATH — override Chrome binary path (useful on VPS/Docker)
# CHROME_PATH=/usr/bin/google-chrome

# WWEBJS_AUTH_PATH — override WhatsApp auth directory (for Docker volumes)
# WWEBJS_AUTH_PATH=/data/.wwebjs_auth
