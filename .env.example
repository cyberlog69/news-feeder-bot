# ════════════════════════════════════════════════════════
#  News Feeder Bot v3.0 — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control!
# ════════════════════════════════════════════════════════

# ── Gemini AI (Required for AI summaries) ────────────────
# Get a free API key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here


# ════════════════════════════════════════════════════════
#  PLATFORM CONFIGURATION
#  Set at least ONE platform. Multiple platforms work simultaneously.
# ════════════════════════════════════════════════════════

# ── WhatsApp (Optional) ───────────────────────────────────
# Supports comma-separated multiple targets:
#   Phone number:  919876543210
#   Group ID:      120363409960337815@g.us
#   Group name:    My Cyber News Group
#   Multi-target:  120363@g.us,919876543210
#
# Run 'npm run list-groups' to find your group IDs.
WHATSAPP_TARGET=


# ── Telegram (Optional) ───────────────────────────────────
# Step 1: Message @BotFather on Telegram → /newbot → copy token
# Step 2: Run 'npm run list-telegram-chats' to find your chat ID
#
# Supports comma-separated multiple targets:
#   Personal chat:   123456789
#   Group:          -987654321
#   Channel:        @mychannel  OR  -1001234567890
#   Multi-target:   @mychannel,-1001234567890
TELEGRAM_BOT_TOKEN=
TELEGRAM_TARGET=


# ── Discord (Optional) ────────────────────────────────────
# Step 1: In Discord: right-click channel → Edit Channel → Integrations → Webhooks → New Webhook
# Step 2: Copy the Webhook URL and paste it below
# Articles will be sent as rich embeds with colored severity indicators.
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=📰 News Feeder Bot
# Optional: URL to a custom avatar image for the Discord bot
DISCORD_AVATAR_URL=


# ════════════════════════════════════════════════════════
#  OPTIONAL OVERRIDES
#  These override settings in config.json.
#  Leave blank to use config.json defaults.
# ════════════════════════════════════════════════════════

# How often to check for new articles (minutes). Default: 5
# POLL_INTERVAL_MINUTES=5

# Maximum articles to send per check cycle. Default: 5
# MAX_ARTICLES_PER_RUN=5

# ════════════════════════════════════════════════════════
#  FEATURE FLAGS
#  Use config.json to fine-tune these features:
#
#  config.filters    — Keyword inclusion/exclusion filtering
#  config.digest     — Daily digest mode (bundle articles into 1 message)
#  config.routing    — Send specific sources to specific platforms
#  config.scoring    — Importance scoring (skip low-value articles)
#  config.severity   — 🚨 CRITICAL ALERT badge for high-priority articles
#  config.settings.dashboardPort     — Web dashboard port (default 3000)
#  config.settings.healthCheckHour   — Hour for daily health check ping (0-23)
# ════════════════════════════════════════════════════════
